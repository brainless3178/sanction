{
    "compilerOptions": {
        "target": "es2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "rootDir": "./src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "resolveJsonModule": true,
        "noImplicitAny": false,
        "typeRoots": [
            "./node_modules/@types",
            "../node_modules/@types"
        ]
    },
    "include": [
        "src/**/*"
    ]
}